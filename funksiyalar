// FunSimple9: Raqamni boshiga qo'shish
void AddLeftDigit(int *son, int raqam) {
    int temp = *son, d = 1;
    while (temp > 0) {
        temp /= 10;
        d *= 10;
    }
    *son = raqam * d + *son;
}

// FunSimple10: Qiymat almashtirish
void Swap(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

// FunSimple11: Kichigini X ga, kattasini Y ga yozish
void Minmax(int *x, int *y) {
    if (*x > *y) {
        int temp = *x;
        *x = *y;
        *y = temp;
    }
}

// FunSimple12: O'sish tartibida saralash
void SortInc3(int *a, int *b, int *c) {
    if (*a > *b) Swap(a, b);
    if (*b > *c) Swap(b, c);
    if (*a > *b) Swap(a, b);
}

// FunSimple13: Kamayish tartibida saralash
void SortDec3(int *a, int *b, int *c) {
    if (*a < *b) Swap(a, b);
    if (*b < *c) Swap(b, c);
    if (*a < *b) Swap(a, b);
}

// FunSimple14: O'ngga siljitish
void ShiftRight3(int *a, int *b, int *c) {
    int temp = *c;
    *c = *b;
    *b = *a;
    *a = temp;
}

// FunSimple15: Chapga siljitish
void ShiftLeft3(int *a, int *b, int *c) {
    int temp = *a;
    *a = *b;
    *b = *c;
    *c = temp;
}

// FunSimple16: Son ishorasini aniqlash
int ishora(double x) {
    if (x < 0) return -1;
    if (x > 0) return 1;
    return 0;
}

// FunSimple17: Kvadrat tenglama ildizlari soni
int RootCount(double a, double b, double c) {
    double D = b * b - 4 * a * c;
    if (D > 0) return 2;
    if (D == 0) return 1;
    return 0;
}

