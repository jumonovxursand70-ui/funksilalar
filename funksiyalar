using namespace std;

// 1-masala: 3-daraja
double PowerA3(double n) {
    return n * n * n;
}

// 2-masala: 2, 3, 4-darajalar
void PowerA234(float a, float &a2, float &a3, float &a4) {
    a2 = a * a;
    a3 = a2 * a;
    a4 = a3 * a;
}

// 3-masala: O'rta arifmetik va geometrik
void MEAN(float x, float y, float &am, float &gm) {
    am = (x + y) / 2.0;
    gm = sqrt(x * y);
}

// 4-masala: Uchburchak P va S
void Triangle(float a, float &P, float &S) {
    P = 3 * a;
    S = (pow(a, 2) * sqrt(3)) / 4;
}

// 5-masala: To'rtburchak koordinata orqali
void RectPS(int x1, int y1, int x2, int y2, int &P, int &S) {
    int a = abs(x1 - x2);
    int b = abs(y1 - y2);
    P = 2 * (a + b);
    S = a * b;
}

// 6-masala: Raqamlar soni va yig'indisi
void DigitCountSum(int n, int &count, int &sum) {
    count = 0; sum = 0;
    n = abs(n);
    if (n == 0) { count = 1; sum = 0; return; }
    while (n > 0) {
        sum += n % 10;
        count++;
        n /= 10;
    }
}

// 7-masala: Raqamlarni teskari qilish
int InvertDigit(int n) {
    int res = 0;
    while (n > 0) {
        res = res * 10 + (n % 10);
        n /= 10;
    }
    return res;
}

// 8-masala: O'ngga raqam qo'shish
int AddRightDigit(int son, int raqam) {
    return son * 10 + raqam;
}

